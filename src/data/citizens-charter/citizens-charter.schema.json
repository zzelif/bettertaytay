{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://bettertaytay.org/schemas/citizens-charter.schema.json",
  "title": "Citizens Charter Raw",
  "description": "Loose schema for raw Citizens Charter extractor output",
  "type": "object",
  "required": ["services"],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": true
    },
    "services": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/service"
      }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "service": {
      "type": "object",
      "required": [
        "service_number",
        "service_name",
        "office_division",
        "requirements",
        "client_steps",
        "fees",
        "processing_time",
        "plain_language_name"
      ],
      "properties": {
        "service_number": { "type": ["string", "null"] },
        "service_name": { "type": ["string", "null"] },
        "plain_language_name": { "type": ["string", "null"] },
        "office_division": { "type": ["string", "null"] },
        "classification": { "type": ["string", "null"] },
        "type_of_transaction": { "type": ["string", "null"] },
        "who_may_avail": { "type": ["string", "null"] },
        "requirements": {
          "type": "array",
          "items": { "$ref": "#/$defs/requirement" }
        },
        "supporting_documents_detail": {
          "type": "object",
          "properties": {
            "instruction": { "type": ["string", "null"] },
            "mandatory_requirements": { "type": "object" },
            "primary_documents": { "type": "array" },
            "additional_documents": { "type": "object" },
            "conditional_requirements": { "type": "object" },
            "note": { "type": ["string", "null"] }
          },
          "additionalProperties": true
        },
        "website": { "type": ["string", "null"] },
        "client_steps": {
          "type": "array",
          "items": { "$ref": "#/$defs/clientStep" }
        },
        "fees": { "$ref": "#/$defs/fee" },
        "fee_schedule": {
          "type": "array",
          "items": { "$ref": "#/$defs/feeItem" }
        },
        "processing_time": { "type": ["string", "null"] },
        "turnaround_time": { "type": ["string", "null"] },
        "notes": { "type": ["string", "null"] },
        "person_responsible": { "type": ["string", "null"] },
        "agency_actions_endorsement": {
          "type": "array",
          "items": { "type": ["string", "null"] }
        }
      },
      "additionalProperties": true
    },
    "requirement": {
      "type": "object",
      "required": ["requirement", "where_to_secure"],
      "properties": {
        "requirement": { "type": ["string", "null"] },
        "where_to_secure": { "type": ["string", "null"] },
        "copies": { "type": ["string", "null"] },
        "serviceSlug": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "clientStep": {
      "type": "object",
      "required": ["step", "action"],
      "properties": {
        "step": { "type": ["number", "string", "null"] },
        "action": { "type": ["string", "null"] },
        "sub_steps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["letter", "action"],
            "properties": {
              "letter": { "type": ["string", "null"] },
              "action": { "type": ["string", "null"] },
              "details": {
                "type": "array",
                "items": { "type": ["string", "null"] }
              }
            },
            "additionalProperties": true
          }
        },
        "url": { "type": ["string", "null"] },
        "processing_time": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "fee": {
      "type": "object",
      "required": ["amount", "description"],
      "properties": {
        "amount": { "type": ["string", "null"] },
        "description": { "type": ["string", "null"] },
        "required": { "type": ["boolean", "null"] }
      },
      "additionalProperties": true
    },
    "feeItem": {
      "type": "object",
      "required": ["name", "amount"],
      "properties": {
        "name": { "type": ["string", "null"] },
        "amount": { "type": ["string", "null"] },
        "processing_time": { "type": ["string", "null"] },
        "office": { "type": ["string", "null"] },
        "category": { "type": ["string", "null"] },
        "url": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    }
  }
}
