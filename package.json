{
  "name": "betterlb-portal",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && npm run merge:services && vite build",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "merge:services": "python3 scripts/merge_citizens_charter.py && npm run merge:data && npx prettier --write src/data/citizens-charter/*.json",
    "merge:data": "python3 scripts/merge_services.py",
    "flag:sessions": "python3 scripts/flag_sessions_for_review.py",
    "wrangler": "wrangler",
    "functions:dev": "npx wrangler pages dev --proxy 5173",
    "generate:sitemap": "node ./scripts/generate-sitemap.js",
    "db:migrate": "./scripts/migrate.sh local",
    "db:migrate:remote": "./scripts/migrate.sh remote",
    "db:migrate:status": "./scripts/migrate.sh status",
    "db:migrate:create": "./scripts/migrate.sh create"
  },
  "dependencies": {
    "@bettergov/kapwa": "^1.2.4",
    "@betterlb/ui": "file:../betterlb-ui",
    "@icons-pack/react-simple-icons": "^13.7.0",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-tabs": "^1.0.4",
    "@testing-library/dom": "^10.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.0",
    "fuse.js": "^7.1.0",
    "i18next": "^25.5.2",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.575.0",
    "meilisearch": "^0.55.0",
    "nuqs": "^2.6.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.71.1",
    "react-i18next": "^15.7.3",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^6.22.2",
    "recharts": "^2.15.3",
    "tailwind-merge": "^2.2.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@cloudflare/workers-types": "^4.20260113.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.9.1",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/vite": "^4.1.13",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/glob": "^8.1.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.5.2",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/ui": "^4.0.18",
    "ajv-formats": "^3.0.1",
    "commander": "^13.1.0",
    "eslint": "^9.9.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "glob": "^10.4.5",
    "globals": "^15.9.0",
    "happy-dom": "^20.7.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.1.6",
    "prettier": "^3.8.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.1.13",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.18",
    "wrangler": "4.70.0"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom",
    "esbuild": "0.25.0",
    "undici": "8.0.2",
    "lucide-react": "^0.575.0"
  }
}
